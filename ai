-- Traceless Remote Monitor Extension v2.1
-- Separate GitHub/loadstring module for your Traceless project.
-- Authorized testing/debugging use inside your own Roblox game environment.
--
-- Use:
-- local InstallRemoteMonitor = loadstring(game:HttpGet(REMOTE_MONITOR_URL))()
-- InstallRemoteMonitor(Library)
--
-- Adds:
-- Library:CreateRemoteMonitorPanel({ Chat = Chat })
-- Library:AddRemoteMonitorToggle(tab, { Chat = Chat })
--
-- Captures outgoing client -> server remotes with hookmetamethod __namecall:
-- RemoteEvent:FireServer(...)
-- RemoteFunction:InvokeServer(...)
--
-- Optional incoming server -> client watcher:
-- Press Incoming in the panel to attach OnClientEvent listeners to common visible roots.

return function(Library)
	local Players = game:GetService("Players")
	local Workspace = game:GetService("Workspace")
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local TweenService = game:GetService("TweenService")
	local UserInputService = game:GetService("UserInputService")

	local LocalPlayer = Players.LocalPlayer
	local VERSION = "Remote Monitor v2.1"
	local Theme = Library.Theme or {}

	local function theme(name, fallback)
		return Theme[name] or fallback
	end

	local function make(className, props, children)
		local obj = Instance.new(className)
		for k, v in pairs(props or {}) do
			obj[k] = v
		end
		for _, child in ipairs(children or {}) do
			child.Parent = obj
		end
		return obj
	end

	local function corner(parent, radius)
		return make("UICorner", {
			CornerRadius = UDim.new(0, radius or 10),
			Parent = parent
		})
	end

	local function stroke(parent, color, thickness, transparency)
		return make("UIStroke", {
			Color = color or theme("StrokeSoft", Color3.fromRGB(42, 42, 48)),
			Thickness = thickness or 1,
			Transparency = transparency or 0.25,
			Parent = parent
		})
	end

	local function padding(parent, left, right, top, bottom)
		return make("UIPadding", {
			PaddingLeft = UDim.new(0, left or 0),
			PaddingRight = UDim.new(0, right or 0),
			PaddingTop = UDim.new(0, top or 0),
			PaddingBottom = UDim.new(0, bottom or 0),
			Parent = parent
		})
	end

	local function hover(button, normal, over)
		button.MouseEnter:Connect(function()
			button.BackgroundColor3 = over
		end)
		button.MouseLeave:Connect(function()
			button.BackgroundColor3 = normal
		end)
	end

	local function safeClipboard(text)
		text = tostring(text or "")
		if type(setclipboard) == "function" then
			setclipboard(text)
			return true
		end
		if type(toclipboard) == "function" then
			toclipboard(text)
			return true
		end
		if type(set_clipboard) == "function" then
			set_clipboard(text)
			return true
		end
		return false
	end

	local function getServiceName(instance)
		local services = {
			[Workspace] = "Workspace",
			[ReplicatedStorage] = "ReplicatedStorage",
			[Players] = "Players"
		}
		return services[instance]
	end

	local function makeSafeLuaPath(instance)
		if not instance then
			return "nil"
		end
		local chain = {}
		local current = instance
		while current and current ~= game do
			table.insert(chain, 1, current)
			current = current.Parent
		end
		local root = chain[1]
		if not root then
			return "nil"
		end
		local rootService = getServiceName(root)
		local path = rootService and ('game:GetService("%s")'):format(rootService) or "game"
		local startIndex = rootService and 2 or 1
		for i = startIndex, #chain do
			local safeName = chain[i].Name:gsub("\\", "\\\\"):gsub('"', '\\"')
			path ..= (':WaitForChild("%s")'):format(safeName)
		end
		return path
	end

	local function short(text, limit)
		text = tostring(text or "")
		limit = limit or 120
		if #text > limit then
			return text:sub(1, limit) .. "...(truncated)"
		end
		return text
	end

	local function previewValue(value, depth, seen)
		depth = depth or 0
		seen = seen or {}
		local valueType = typeof(value)

		if valueType == "Instance" then
			local ok, fullName = pcall(function()
				return value:GetFullName()
			end)
			return value.ClassName .. " <" .. (ok and fullName or value.Name) .. ">"
		end

		if valueType == "string" then
			return '"' .. short(value:gsub("\n", "\\n"), 140) .. '"'
		end

		if valueType == "number" or valueType == "boolean" or valueType == "nil" then
			return tostring(value)
		end

		if valueType == "Vector3" then
			return ("Vector3(%.2f, %.2f, %.2f)"):format(value.X, value.Y, value.Z)
		end

		if valueType == "Vector2" then
			return ("Vector2(%.2f, %.2f)"):format(value.X, value.Y)
		end

		if valueType == "CFrame" then
			local p = value.Position
			return ("CFrame(%.2f, %.2f, %.2f)"):format(p.X, p.Y, p.Z)
		end

		if valueType == "Color3" then
			return ("Color3(%d, %d, %d)"):format(value.R * 255, value.G * 255, value.B * 255)
		end

		if valueType == "EnumItem" then
			return tostring(value)
		end

		if valueType == "table" then
			if seen[value] then
				return "{cycle}"
			end
			if depth >= 2 then
				return "{...}"
			end
			seen[value] = true
			local parts = {}
			local count = 0
			for k, v in pairs(value) do
				count += 1
				if count > 8 then
					table.insert(parts, "...more")
					break
				end
				table.insert(parts, "[" .. previewValue(k, depth + 1, seen) .. "]=" .. previewValue(v, depth + 1, seen))
			end
			return "{" .. table.concat(parts, ", ") .. "}"
		end

		return valueType .. "(" .. tostring(value) .. ")"
	end

	local function buildArgsPreview(args)
		local lines = {}
		for i, value in ipairs(args or {}) do
			table.insert(lines, tostring(i) .. ". " .. typeof(value) .. " = " .. previewValue(value))
		end
		if #lines == 0 then
			return "(no args)"
		end
		return table.concat(lines, "\n")
	end


	local function luaQuote(text)
		text = tostring(text or "")
		return string.format("%q", text)
	end

	local function valueToLua(value, depth, seen)
		depth = depth or 0
		seen = seen or {}

		local valueType = typeof(value)

		if valueType == "nil" then
			return "nil"
		end

		if valueType == "string" then
			return luaQuote(value)
		end

		if valueType == "number" then
			if value ~= value or value == math.huge or value == -math.huge then
				return "0 --[[ unsupported number ]]"
			end

			return tostring(value)
		end

		if valueType == "boolean" then
			return tostring(value)
		end

		if valueType == "Instance" then
			return makeSafeLuaPath(value)
		end

		if valueType == "Vector3" then
			return ("Vector3.new(%s, %s, %s)"):format(tostring(value.X), tostring(value.Y), tostring(value.Z))
		end

		if valueType == "Vector2" then
			return ("Vector2.new(%s, %s)"):format(tostring(value.X), tostring(value.Y))
		end

		if valueType == "CFrame" then
			local components = { value:GetComponents() }

			for i, component in ipairs(components) do
				components[i] = tostring(component)
			end

			return "CFrame.new(" .. table.concat(components, ", ") .. ")"
		end

		if valueType == "Color3" then
			return ("Color3.fromRGB(%d, %d, %d)"):format(math.floor(value.R * 255), math.floor(value.G * 255), math.floor(value.B * 255))
		end

		if valueType == "EnumItem" then
			return tostring(value)
		end

		if valueType == "table" then
			if seen[value] then
				return "{} --[[ cycle ]]"
			end

			if depth >= 3 then
				return "{} --[[ table too deep ]]"
			end

			seen[value] = true

			local parts = {}
			local arrayIndex = 1

			for k, v in pairs(value) do
				local keyLua

				if type(k) == "number" and k == arrayIndex then
					keyLua = nil
					arrayIndex += 1
				elseif type(k) == "string" and k:match("^[%a_][%w_]*$") then
					keyLua = k .. " = "
				else
					keyLua = "[" .. valueToLua(k, depth + 1, seen) .. "] = "
				end

				table.insert(parts, "\t" .. (keyLua or "") .. valueToLua(v, depth + 1, seen))
			end

			if #parts == 0 then
				return "{}"
			end

			return "{\n" .. table.concat(parts, ",\n") .. "\n}"
		end

		return "nil --[[ unsupported " .. valueType .. " ]]"
	end

	local function getRunnableState(log)
		if not log then
			return false, "No remote selected."
		end

		if log.Direction ~= "Client -> Server" then
			return false, "Only outgoing Client -> Server logs can be replayed."
		end

		if typeof(log.Remote) ~= "Instance" then
			return false, "Remote instance is missing."
		end

		if log.Method == "FireServer" and log.Remote:IsA("RemoteEvent") then
			return true, "Runnable FireServer log."
		end

		if log.Method == "InvokeServer" and log.Remote:IsA("RemoteFunction") then
			return true, "Runnable InvokeServer log."
		end

		if log.Method == "OnClientEvent" then
			return false, "Incoming OnClientEvent logs cannot be replayed with FireServer."
		end

		return false, "Remote/method mismatch: " .. tostring(log.Remote.ClassName) .. " cannot use " .. tostring(log.Method) .. "."
	end

	local function buildRunnerCode(log)
		if not log then
			return "-- No remote selected."
		end

		local runnable, reason = getRunnableState(log)

		if not runnable then
			return table.concat({
				"-- Packaged by Traceless Remote Monitor",
				"-- Not runnable from the client.",
				"-- Reason: " .. tostring(reason),
				"-- Direction: " .. tostring(log.Direction),
				"-- Method: " .. tostring(log.Method),
				"-- Remote: " .. tostring(log.RemoteFullName or log.RemoteName or "Unknown"),
				"",
				"-- This log is still useful for inspection/copying context,",
				"-- but the Run button only replays outgoing Client -> Server remotes."
			}, "\n")
		end

		local remotePath = tostring(log.RemotePath or "nil")
		local args = log.ArgsRaw or {}
		local argLines = {}

		for _, value in ipairs(args) do
			table.insert(argLines, "\t" .. valueToLua(value, 1, {}))
		end

		local method = tostring(log.Method or "FireServer")
		local callLine

		if method == "InvokeServer" then
			callLine = "local result = remote:InvokeServer(unpack(args))\nprint(\"Remote result:\", result)"
		else
			callLine = "remote:FireServer(unpack(args))"
		end

		return table.concat({
			"-- Packaged by Traceless Remote Monitor",
			"-- Remote: " .. tostring(log.RemoteFullName or log.RemoteName or "Unknown"),
			"-- Method: " .. method,
			"",
			"local remote = " .. remotePath,
			"",
			"local args = {",
			table.concat(argLines, ",\n"),
			"}",
			"",
			callLine
		}, "\n")
	end

	local function buildRemoteContext(log)
		if not log then
			return "No remote log selected."
		end
		return table.concat({
			"[Traceless Remote Monitor]",
			"Direction: " .. tostring(log.Direction),
			"Method: " .. tostring(log.Method),
			"Remote Name: " .. tostring(log.RemoteName),
			"Remote Class: " .. tostring(log.RemoteClass),
			"Remote FullName: " .. tostring(log.RemoteFullName),
			"Remote LuaPath: " .. tostring(log.RemotePath),
			"First/Last Time: " .. tostring(log.TimeText),
			"Same Remote Count: " .. tostring(log.Count or 1),
			"Latest Args Count: " .. tostring(log.ArgsCount),
			"Runnable: " .. tostring(select(1, getRunnableState(log))),
			"Run Note: " .. tostring(select(2, getRunnableState(log))),
			"",
			"Args:",
			tostring(log.ArgsPreview or "(no args)"),
			"",
			"Packaged Runner:",
			buildRunnerCode(log)
		}, "\n")
	end

	local function getPanelSize()
		local camera = Workspace.CurrentCamera
		local viewport = camera and camera.ViewportSize or Vector2.new(900, 600)
		local mobile = viewport.X <= 760

		-- Smaller, cleaner monitor window.
		local width = mobile
			and math.floor(math.clamp(viewport.X * 0.78, 294, math.max(294, viewport.X - 24)))
			or math.floor(math.clamp(viewport.X * 0.30, 330, 370))

		local height = mobile
			and math.floor(math.clamp(viewport.Y * 0.58, 310, math.max(310, viewport.Y - 110)))
			or math.floor(math.clamp(viewport.Y * 0.58, 360, 445))

		local xOffset = mobile and 8 or 12
		local yOffset = -math.floor(height / 2)
		return mobile, width, height, xOffset, yOffset
	end


	local function getCallerScriptInfo()
		local callerScript = nil

		if type(getcallingscript) == "function" then
			local ok, result = pcall(getcallingscript)

			if ok and typeof(result) == "Instance" then
				callerScript = result
			end
		end

		if callerScript then
			return {
				Instance = callerScript,
				Name = callerScript.Name,
				ClassName = callerScript.ClassName,
				FullName = callerScript:GetFullName(),
				Path = makeSafeLuaPath(callerScript)
			}
		end

		local debugSource = nil

		if debug and type(debug.info) == "function" then
			for level = 3, 9 do
				local ok, source = pcall(debug.info, level, "s")

				if ok and type(source) == "string" and source ~= "" and source ~= "[C]" then
					debugSource = source
					break
				end
			end
		end

		return {
			Instance = nil,
			Name = debugSource or "Unknown",
			ClassName = "Unknown",
			FullName = debugSource or "Unknown",
			Path = debugSource or "Unavailable"
		}
	end

	--// Global hook state
	local GlobalStore = (type(getgenv) == "function" and getgenv()) or _G
	GlobalStore.__TracelessRemoteMonitor = GlobalStore.__TracelessRemoteMonitor or {
		Hooked = false,
		Active = false,
		IgnoreDepth = 0,
		Monitors = {},
		NextMonitorId = 0,
		OldNamecall = nil,
		LastHookError = nil
	}

	local HookState = GlobalStore.__TracelessRemoteMonitor

	local function registerMonitor(monitor)
		HookState.NextMonitorId += 1
		local id = HookState.NextMonitorId
		HookState.Monitors[id] = monitor
		return id
	end

	local function unregisterMonitor(id)
		HookState.Monitors[id] = nil
	end

	local function installNamecallHook()
		if HookState.Hooked then
			return true, "Already hooked."
		end
		if type(hookmetamethod) ~= "function" then
			HookState.LastHookError = "hookmetamethod is not available."
			return false, HookState.LastHookError
		end
		if type(getnamecallmethod) ~= "function" then
			HookState.LastHookError = "getnamecallmethod is not available."
			return false, HookState.LastHookError
		end

		local wrap = type(newcclosure) == "function" and newcclosure or function(fn)
			return fn
		end

		local oldNamecall
		local ok, result = pcall(function()
			oldNamecall = hookmetamethod(game, "__namecall", wrap(function(self, ...)
				local method = getnamecallmethod()

				if HookState.Active
					and (HookState.IgnoreDepth or 0) <= 0
					and (method == "FireServer" or method == "InvokeServer")
					and typeof(self) == "Instance" then

					-- v2.1 IMPORTANT:
					-- Keep the hook extremely tiny.
					-- Do NOT call self:IsA(), self.ClassName, debug.info, or checkcaller() here.
					-- Some environments report checkcaller() as true inside hooks and skip all game calls.
					-- We only capture method + instance + args, then validate later outside the hook.
					local remote = self
					local remoteMethod = method
					local remoteArgs = { ... }

					for _, monitor in pairs(HookState.Monitors) do
						if monitor and monitor.Enabled and monitor.OutgoingEnabled and type(monitor.LogOutgoing) == "function" then
							task.defer(function()
								pcall(monitor.LogOutgoing, remote, remoteMethod, remoteArgs)
							end)
						end
					end
				end

				return oldNamecall(self, ...)
			end))
		end)

		if not ok then
			HookState.LastHookError = tostring(result)
			return false, HookState.LastHookError
		end

		HookState.Hooked = true
		HookState.OldNamecall = oldNamecall
		HookState.LastHookError = nil
		return true, "Hook installed."
	end

	function Library:CreateRemoteMonitorPanel(config)
		config = config or {}
		if self.RemoteMonitorPanel and self.RemoteMonitorPanel.Gui then
			return self.RemoteMonitorPanel
		end

		local chat = config.Chat
		local maxLogs = tonumber(config.MaxLogs) or 150
		local parent = self:GetParent()
		local _, width, height, xOffset, yOffset = getPanelSize()

		local panel = {
			Open = false,
			Enabled = true,

			-- Outgoing is OFF by default.
			-- This prevents the game from being affected just by executing/loading the monitor.
			OutgoingEnabled = false,
			IncomingEnabled = false,

			-- v1.8 groups by the same remote + direction + method only.
			-- If args change, the existing row updates to the latest args.
			LogsBySignature = {},

			Logs = {},
			LatestLog = nil,
			SelectedLog = nil,
			IncomingConnections = {},
			DescendantConnections = {},
			MonitorId = nil
		}

		local gui = make("ScreenGui", {
			Name = "TracelessRemoteMonitorPanel",
			ResetOnSpawn = false,
			IgnoreGuiInset = true,
			ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
			Parent = parent
		})

		local main = make("Frame", {
			Size = UDim2.fromOffset(width, height),
			Position = UDim2.new(0, -width - 20, 0.5, yOffset),
			BackgroundColor3 = theme("Window", Color3.fromRGB(12, 12, 15)),
			BorderSizePixel = 0,
			Visible = false,
			ClipsDescendants = true,
			Parent = gui
		})
		corner(main, 14)
		stroke(main, theme("Stroke", Color3.fromRGB(65, 65, 72)), 1, 0.18)

		local header = make("Frame", {
			Size = UDim2.new(1, 0, 0, 46),
			BackgroundColor3 = theme("Header", Color3.fromRGB(18, 18, 22)),
			BorderSizePixel = 0,
			Parent = main
		})
		corner(header, 14)

		make("TextLabel", {
			Size = UDim2.new(1, -94, 1, 0),
			Position = UDim2.fromOffset(12, 0),
			BackgroundTransparency = 1,
			Text = "Remote Monitor  •  v2.1",
			TextColor3 = theme("Text", Color3.fromRGB(240, 240, 245)),
			TextXAlignment = Enum.TextXAlignment.Left,
			Font = Enum.Font.GothamBold,
			TextSize = 13,
			Parent = header
		})

		local closeButton = make("TextButton", {
			Size = UDim2.fromOffset(34, 30),
			Position = UDim2.new(1, -42, 0, 8),
			BackgroundColor3 = theme("Button", Color3.fromRGB(42, 42, 48)),
			BorderSizePixel = 0,
			Text = "×",
			TextColor3 = theme("Text", Color3.fromRGB(240, 240, 245)),
			Font = Enum.Font.GothamBold,
			TextSize = 18,
			AutoButtonColor = false,
			Parent = header
		})
		corner(closeButton, 9)
		hover(closeButton, theme("Button", Color3.fromRGB(42, 42, 48)), theme("ButtonHover", Color3.fromRGB(57, 57, 65)))

		-- Draggable Remote Monitor window.
		do
			local dragging = false
			local dragStart = nil
			local startPos = nil

			header.InputBegan:Connect(function(inputObject)
				if inputObject.UserInputType == Enum.UserInputType.MouseButton1 or inputObject.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					dragStart = inputObject.Position
					startPos = main.Position
				end
			end)

			header.InputEnded:Connect(function(inputObject)
				if inputObject.UserInputType == Enum.UserInputType.MouseButton1 or inputObject.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			UserInputService.InputChanged:Connect(function(inputObject)
				if not dragging then
					return
				end

				if inputObject.UserInputType ~= Enum.UserInputType.MouseMovement and inputObject.UserInputType ~= Enum.UserInputType.Touch then
					return
				end

				local delta = inputObject.Position - dragStart

				main.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
			end)
		end

		local statusLabel = make("TextLabel", {
			Size = UDim2.new(1, -22, 0, 26),
			Position = UDim2.fromOffset(11, 52),
			BackgroundColor3 = theme("Panel2", Color3.fromRGB(24, 24, 28)),
			BorderSizePixel = 0,
			Text = "Status: installing hook...",
			TextColor3 = theme("Muted", Color3.fromRGB(155, 155, 165)),
			TextXAlignment = Enum.TextXAlignment.Left,
			Font = Enum.Font.GothamBold,
			TextSize = 10,
			Parent = main
		})
		corner(statusLabel, 8)
		padding(statusLabel, 8, 8, 0, 0)

		local toolbar = make("Frame", {
			Size = UDim2.new(1, -22, 0, 34),
			Position = UDim2.fromOffset(11, 84),
			BackgroundTransparency = 1,
			Parent = main
		})

		local function makeButton(parentFrame, text, xScale, widthScale, callback)
			local button = make("TextButton", {
				Size = UDim2.new(widthScale, -5, 1, 0),
				Position = UDim2.new(xScale, 0, 0, 0),
				BackgroundColor3 = theme("Button", Color3.fromRGB(42, 42, 48)),
				BorderSizePixel = 0,
				Text = text,
				TextColor3 = theme("Text", Color3.fromRGB(240, 240, 245)),
				Font = Enum.Font.GothamBold,
				TextSize = 10,
				AutoButtonColor = false,
				Parent = parentFrame
			})
			corner(button, 8)
			hover(button, theme("Button", Color3.fromRGB(42, 42, 48)), theme("ButtonHover", Color3.fromRGB(57, 57, 65)))
			button.MouseButton1Click:Connect(function()
				if callback then
					task.spawn(callback)
				end
			end)
			return button
		end

		local logList = make("ScrollingFrame", {
			Size = UDim2.new(1, -22, 0, math.floor((height - 168) * 0.44)),
			Position = UDim2.fromOffset(11, 124),
			BackgroundColor3 = theme("Background", Color3.fromRGB(8, 8, 10)),
			BorderSizePixel = 0,
			ScrollBarThickness = 4,
			CanvasSize = UDim2.fromOffset(0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			Parent = main
		})
		corner(logList, 10)
		stroke(logList)
		padding(logList, 6, 6, 6, 6)
		make("UIListLayout", {
			Padding = UDim.new(0, 4),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = logList
		})

		local detailsY = 132 + math.floor((height - 168) * 0.44)

		local detailsFrame = make("ScrollingFrame", {
			Size = UDim2.new(1, -22, 1, -(detailsY + 52)),
			Position = UDim2.fromOffset(11, detailsY),
			BackgroundColor3 = theme("Background", Color3.fromRGB(8, 8, 10)),
			BorderSizePixel = 0,
			ScrollBarThickness = 4,
			CanvasSize = UDim2.fromOffset(0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			ScrollingDirection = Enum.ScrollingDirection.Y,
			Parent = main
		})

		corner(detailsFrame, 10)
		stroke(detailsFrame)
		padding(detailsFrame, 8, 8, 8, 8)

		local detailsBox = make("TextBox", {
			Size = UDim2.new(1, -8, 0, 120),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Text = "Select a remote log.",
			TextColor3 = theme("Text", Color3.fromRGB(240, 240, 245)),
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			TextWrapped = true,
			TextEditable = false,
			MultiLine = true,
			ClearTextOnFocus = false,
			Font = Enum.Font.Code,
			TextSize = 10,
			Parent = detailsFrame
		})

		local bottom = make("Frame", {
			Size = UDim2.new(1, -22, 0, 34),
			Position = UDim2.new(0, 11, 1, -40),
			BackgroundTransparency = 1,
			Parent = main
		})

		local pauseButton, outgoingButton, incomingButton

		local function notify(title, message, duration)
			if Library.Notify then
				Library:Notify(title, message, duration or 2)
			end
		end

		local function updateStatus()
			local hookText = HookState.Hooked and "hooked" or "not hooked"
			local pauseText = panel.Enabled and "logging" or "paused"
			local outgoingText = panel.OutgoingEnabled and "outgoing on" or "outgoing off"
			local incomingText = panel.IncomingEnabled and "incoming on" or "incoming off"

			statusLabel.Text = "Status: " .. hookText .. " | " .. pauseText .. " | " .. outgoingText .. " | " .. incomingText .. " | grouped logs: " .. tostring(#panel.Logs)

			if pauseButton then
				pauseButton.Text = panel.Enabled and "Pause" or "Resume"
			end

			if outgoingButton then
				outgoingButton.Text = panel.OutgoingEnabled and "Outgoing On" or "Outgoing Off"
			end

			if incomingButton then
				incomingButton.Text = panel.IncomingEnabled and "Incoming On" or "Incoming Off"
			end
		end

		local function clearLogRows()
			for _, child in ipairs(logList:GetChildren()) do
				if child:IsA("GuiObject") then
					child:Destroy()
				end
			end
		end

		local function updateDetailsText(text)
			text = tostring(text or "")
			detailsBox.Text = text

			task.defer(function()
				local width = math.max(180, detailsFrame.AbsoluteSize.X - 22)
				local lineCount = 1

				for _ in text:gmatch("\n") do
					lineCount += 1
				end

				local wrapEstimate = math.ceil(#text / math.max(width / 7, 1))
				local estimatedHeight = math.max(120, lineCount * 15 + wrapEstimate * 12 + 34)

				detailsBox.Size = UDim2.new(1, -8, 0, estimatedHeight)
				detailsFrame.CanvasPosition = Vector2.new(0, 0)
			end)
		end

		local function showLogDetails(log)
			panel.SelectedLog = log
			updateDetailsText(buildRemoteContext(log))
		end

		local function argsSignature(args)
			args = args or {}

			local parts = {}

			for i, value in ipairs(args) do
				table.insert(parts, tostring(i) .. ":" .. typeof(value) .. "=" .. previewValue(value, 0, {}))
			end

			return table.concat(parts, "|")
		end

		local function getLogSignature(direction, remote, method, args)
			local remoteName = "UnknownRemote"

			if typeof(remote) == "Instance" then
				local ok, result = pcall(function()
					return remote:GetFullName()
				end)

				remoteName = (ok and result) or remote.Name
			end

			-- v1.8 grouping:
			-- Same remote + same method + same direction = same row.
			-- Args do not need to match. The row updates to the latest args.
			return tostring(direction) .. "|" .. tostring(method) .. "|" .. remoteName
		end

		local function updateLogRow(log)
			if not log or not log.Row or not log.Row.Parent then
				return
			end

			local directionShort = log.Direction == "Server -> Client" and "IN" or "OUT"
			local countText = log.Count and log.Count > 1 and (" x" .. tostring(log.Count)) or ""
			log.Row.Text = "[" .. directionShort .. countText .. "] " .. log.RemoteName .. "  •  " .. log.Method .. "  •  latest args: " .. tostring(log.ArgsCount)

			if panel.SelectedLog == log then
				updateDetailsText(buildRemoteContext(log))
			end
		end

		local function addLogRow(log)
			local directionShort = log.Direction == "Server -> Client" and "IN" or "OUT"
			local countText = log.Count and log.Count > 1 and (" x" .. tostring(log.Count)) or ""

			local row = make("TextButton", {
				Size = UDim2.new(1, 0, 0, 30),
				BackgroundColor3 = theme("Panel2", Color3.fromRGB(24, 24, 28)),
				BorderSizePixel = 0,
				Text = "[" .. directionShort .. countText .. "] " .. log.RemoteName .. "  •  " .. log.Method .. "  •  latest args: " .. tostring(log.ArgsCount),
				TextColor3 = theme("Text", Color3.fromRGB(240, 240, 245)),
				TextXAlignment = Enum.TextXAlignment.Left,
				TextTruncate = Enum.TextTruncate.AtEnd,
				Font = Enum.Font.GothamBold,
				TextSize = 10,
				AutoButtonColor = false,
				Parent = logList
			})

			log.Row = row

			corner(row, 7)
			padding(row, 7, 7, 0, 0)
			hover(row, theme("Panel2", Color3.fromRGB(24, 24, 28)), theme("ButtonHover", Color3.fromRGB(57, 57, 65)))

			row.MouseButton1Click:Connect(function()
				showLogDetails(log)
			end)

			task.defer(function()
				logList.CanvasPosition = Vector2.new(0, math.max(0, logList.AbsoluteCanvasSize.Y))
			end)
		end

		function panel:AddRemoteLog(direction, remote, method, args)
			if not panel.Enabled then
				return
			end

			if typeof(remote) ~= "Instance" then
				return
			end

			local className = remote.ClassName

			if method == "FireServer" and className ~= "RemoteEvent" then
				return
			end

			if method == "InvokeServer" and className ~= "RemoteFunction" then
				return
			end

			args = args or {}

			local signature = getLogSignature(direction, remote, method, args)
			local existingLog = panel.LogsBySignature[signature]

			if existingLog then
				existingLog.Count = (existingLog.Count or 1) + 1
				existingLog.LastTimeText = os.date("%H:%M:%S")
				existingLog.TimeText = existingLog.LastTimeText

				-- Keep this grouped row updated with the latest args.
				-- When you select/click this row later, it already shows the newest captured args.
				existingLog.ArgsCount = #args
				existingLog.ArgsRaw = args
				existingLog.ArgsPreview = buildArgsPreview(args)
				existingLog.RunnerCode = buildRunnerCode(existingLog)

				panel.LatestLog = existingLog

				updateLogRow(existingLog)

				-- Do NOT force-switch the selected row every time a remote fires.
				-- Only refresh the details if the user already has this exact row selected.
				if panel.SelectedLog == existingLog then
					showLogDetails(existingLog)
				end

				updateStatus()
				return
			end

			local log = {
				Direction = tostring(direction or "Unknown"),
				Method = tostring(method or "Unknown"),
				Remote = remote,
				RemoteName = remote.Name,
				RemoteClass = remote.ClassName,
				RemoteFullName = remote:GetFullName(),
				RemotePath = makeSafeLuaPath(remote),
				TimeText = os.date("%H:%M:%S"),
				LastTimeText = os.date("%H:%M:%S"),
				Count = 1,
				Signature = signature,
				ArgsCount = #args,
				ArgsRaw = args,
				ArgsPreview = buildArgsPreview(args),
				RunnerCode = nil
			}

			log.RunnerCode = buildRunnerCode(log)

			table.insert(panel.Logs, log)
			panel.LogsBySignature[signature] = log
			panel.LatestLog = log

			if not panel.SelectedLog then
				panel.SelectedLog = log
			end

			while #panel.Logs > maxLogs do
				local removed = table.remove(panel.Logs, 1)

				if removed and removed.Signature then
					panel.LogsBySignature[removed.Signature] = nil
				end

				if removed and removed.Row and removed.Row.Parent then
					removed.Row:Destroy()
				else
					local first = logList:FindFirstChildWhichIsA("TextButton")

					if first then
						first:Destroy()
					end
				end
			end

			addLogRow(log)

			-- Only auto-show details when nothing was selected yet.
			if panel.SelectedLog == log then
				showLogDetails(log)
			end

			updateStatus()
		end

		function panel.LogOutgoing(remote, method, args)
			panel:AddRemoteLog("Client -> Server", remote, method, args)
		end

		local function disconnectIncoming()
			for _, connection in pairs(panel.IncomingConnections) do
				pcall(function()
					connection:Disconnect()
				end)
			end
			for _, connection in pairs(panel.DescendantConnections) do
				pcall(function()
					connection:Disconnect()
				end)
			end
			panel.IncomingConnections = {}
			panel.DescendantConnections = {}
		end

		local function watchRemoteEvent(remote)
			if not remote or not remote:IsA("RemoteEvent") then
				return
			end
			if panel.IncomingConnections[remote] then
				return
			end
			local ok, connection = pcall(function()
				return remote.OnClientEvent:Connect(function(...)
					panel:AddRemoteLog("Server -> Client", remote, "OnClientEvent", { ... })
				end)
			end)
			if ok and connection then
				panel.IncomingConnections[remote] = connection
			end
		end

		local function watchIncomingRoot(root)
			if not root then
				return
			end
			for _, item in ipairs(root:GetDescendants()) do
				if item:IsA("RemoteEvent") then
					watchRemoteEvent(item)
				end
			end
			local ok, connection = pcall(function()
				return root.DescendantAdded:Connect(function(item)
					if panel.IncomingEnabled and item:IsA("RemoteEvent") then
						watchRemoteEvent(item)
					end
				end)
			end)
			if ok and connection then
				table.insert(panel.DescendantConnections, connection)
			end
		end

		function panel:SetOutgoingEnabled(enabled)
			panel.OutgoingEnabled = enabled == true
			HookState.Active = panel.OutgoingEnabled

			if panel.OutgoingEnabled then
				local hookOk, hookMessage = installNamecallHook()

				if hookOk then
					statusLabel.Text = "Status: outgoing hook ready."
					statusLabel.TextColor3 = theme("Success", Color3.fromRGB(50, 88, 62))
					notify("Remote Monitor", "Outgoing logging enabled with tiny method-only hook.", 2)
				else
					panel.OutgoingEnabled = false
					HookState.Active = false
					statusLabel.Text = "Status: " .. tostring(hookMessage)
					statusLabel.TextColor3 = theme("Error", Color3.fromRGB(105, 50, 52))
					notify("Remote Monitor", tostring(hookMessage), 4)
				end
			else
				HookState.Active = false
				notify("Remote Monitor", "Outgoing logging disabled.", 2)
			end

			updateStatus()
		end

		function panel:SetIncomingEnabled(enabled)
			panel.IncomingEnabled = enabled == true
			disconnectIncoming()
			if panel.IncomingEnabled then
				watchIncomingRoot(ReplicatedStorage)
				watchIncomingRoot(Workspace)
				if LocalPlayer then
					watchIncomingRoot(LocalPlayer:FindFirstChildOfClass("PlayerGui"))
					watchIncomingRoot(LocalPlayer:FindFirstChildOfClass("Backpack"))
				end
				notify("Remote Monitor", "Incoming RemoteEvents are being watched.", 2)
			end
			updateStatus()
		end

		function panel:OpenPanel()
			if panel.Open then
				return
			end
			panel.Open = true
			main.Visible = true
			local _, newWidth, newHeight, newXOffset, newYOffset = getPanelSize()
			main.Size = UDim2.fromOffset(newWidth, newHeight)
			main.Position = UDim2.new(0, -newWidth - 20, 0.5, newYOffset)
			TweenService:Create(main, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new(0, newXOffset, 0.5, newYOffset)
			}):Play()
			updateStatus()
		end

		function panel:ClosePanel()
			panel.Open = false
			local _, newWidth, _, _, newYOffset = getPanelSize()
			TweenService:Create(main, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				Position = UDim2.new(0, -newWidth - 20, 0.5, newYOffset)
			}):Play()
			task.delay(0.17, function()
				if not panel.Open then
					main.Visible = false
				end
			end)
		end

		function panel:Toggle()
			if panel.Open then
				panel:ClosePanel()
			else
				panel:OpenPanel()
			end
		end

		function panel:Clear()
			panel.Logs = {}
			panel.LogsBySignature = {}
			panel.LatestLog = nil
			panel.SelectedLog = nil
			updateDetailsText("Logs cleared.")
			clearLogRows()
			updateStatus()
		end

		function panel:PasteSelectedToChat()
			if not panel.SelectedLog then
				notify("Remote Monitor", "Select a log first.", 2)
				return
			end
			local context = "\n\n" .. buildRemoteContext(panel.SelectedLog) .. "\n"
			if chat and chat.AppendToInput then
				chat:AppendToInput(context)
				notify("Remote Monitor", "Remote context pasted to AI chat.", 2)
			elseif safeClipboard(context) then
				notify("Remote Monitor", "No chat linked. Context copied.", 2)
			else
				notify("Remote Monitor", "No chat linked.", 2)
			end
		end


		function panel:CopyRunnerCode()
			if not panel.SelectedLog then
				notify("Remote Monitor", "Select a log first.", 2)
				return
			end

			local runnerCode = buildRunnerCode(panel.SelectedLog)

			if safeClipboard(runnerCode) then
				notify("Remote Monitor", "Packaged runner copied.", 2)
			else
				updateDetailsText(runnerCode)
				notify("Remote Monitor", "Clipboard unavailable. Runner shown in details.", 3)
			end
		end

		function panel:PasteRunnerToChat()
			if not panel.SelectedLog then
				notify("Remote Monitor", "Select a log first.", 2)
				return
			end

			local runnerCode = "\n\n```lua\n" .. buildRunnerCode(panel.SelectedLog) .. "\n```\n"

			if chat and chat.AppendToInput then
				chat:AppendToInput(runnerCode)
				notify("Remote Monitor", "Runner code pasted to AI chat.", 2)
			elseif safeClipboard(runnerCode) then
				notify("Remote Monitor", "No chat linked. Runner copied.", 2)
			else
				notify("Remote Monitor", "No chat linked.", 2)
			end
		end

		function panel:RunSelectedRemote()
			if not panel.SelectedLog then
				notify("Remote Monitor", "Select a log first.", 2)
				return
			end

			local log = panel.SelectedLog
			local runnable, reason = getRunnableState(log)

			if not runnable then
				notify("Remote Monitor", tostring(reason), 4)
				updateDetailsText(buildRemoteContext(log))
				return
			end

			local remote = log.Remote
			local args = log.ArgsRaw or {}

			task.spawn(function()
				local ok, result = pcall(function()
					HookState.IgnoreDepth = (HookState.IgnoreDepth or 0) + 1

					local callOk, callResult = pcall(function()
						if log.Method == "InvokeServer" then
							return remote:InvokeServer(unpack(args))
						end

						remote:FireServer(unpack(args))
						return "FireServer sent."
					end)

					HookState.IgnoreDepth = math.max(0, (HookState.IgnoreDepth or 1) - 1)

					if not callOk then
						error(callResult)
					end

					return callResult
				end)

				if ok then
					notify("Remote Monitor", tostring(result), 2)
				else
					HookState.IgnoreDepth = 0
					notify("Remote Monitor", "Run failed: " .. tostring(result), 4)
				end
			end)
		end

		function panel:FindSelectedInDex()
			if not panel.SelectedLog or not panel.SelectedLog.Remote then
				notify("Remote Monitor", "Select a log first.", 2)
				return
			end
			local dexPanel = Library.DexPanel
			if dexPanel and dexPanel.FocusObject then
				dexPanel:OpenPanel()
				dexPanel:FocusObject(panel.SelectedLog.Remote)
				notify("Remote Monitor", "Remote focused in Dex.", 2)
			else
				notify("Remote Monitor", "Dex panel not found.", 2)
			end
		end

		pauseButton = makeButton(toolbar, "Pause", 0, 0.25, function()
			panel.Enabled = not panel.Enabled
			updateStatus()
		end)

		outgoingButton = makeButton(toolbar, "Outgoing Off", 0.25, 0.25, function()
			panel:SetOutgoingEnabled(not panel.OutgoingEnabled)
		end)

		incomingButton = makeButton(toolbar, "Incoming Off", 0.5, 0.25, function()
			panel:SetIncomingEnabled(not panel.IncomingEnabled)
		end)

		makeButton(toolbar, "Clear", 0.75, 0.25, function()
			panel:Clear()
		end)

		makeButton(bottom, "AI", 0, 0.25, function()
			panel:PasteSelectedToChat()
		end)

		makeButton(bottom, "Dex", 0.25, 0.25, function()
			panel:FindSelectedInDex()
		end)

		makeButton(bottom, "CopyRun", 0.5, 0.25, function()
			panel:CopyRunnerCode()
		end)

		makeButton(bottom, "Run", 0.75, 0.25, function()
			panel:RunSelectedRemote()
		end)

		closeButton.MouseButton1Click:Connect(function()
			panel:ClosePanel()
		end)

		UserInputService.InputBegan:Connect(function(inputObject, gameProcessed)
			if gameProcessed then
				return
			end
			if inputObject.KeyCode == Enum.KeyCode.Escape and panel.Open then
				panel:ClosePanel()
			end
		end)

		statusLabel.Text = "Status: ready. Outgoing hook is off."
		statusLabel.TextColor3 = theme("Muted", Color3.fromRGB(155, 155, 165))

		panel.MonitorId = registerMonitor(panel)

		function panel:Destroy()
			disconnectIncoming()
			unregisterMonitor(panel.MonitorId)
			if gui then
				gui:Destroy()
			end
		end

		updateStatus()
		self.RemoteMonitorPanel = panel
		return panel
	end

	function Library:AddRemoteMonitorToggle(tab, config)
		config = config or {}
		local panel = self:CreateRemoteMonitorPanel({
			Chat = config.Chat,
			MaxLogs = config.MaxLogs or 150
		})
		tab:AddButton("Toggle Remote Monitor", function()
			panel:Toggle()
		end)
		tab:AddLabel("Remote Monitor v2.1: tiny method-only hook, no checkcaller skip, grouped rows keep latest args.")
		return panel
	end

	Library.Extensions = Library.Extensions or {}
	Library.Extensions.RemoteMonitor = {
		Version = VERSION,
		Name = "Traceless Remote Monitor"
	}

	return Library
end
